{
  "mcpServers": {
    "google-ads": {
      "type": "http",
      "url": "${GOOGLE_ADS_MCP_URL:-https://mcp.google-ads.example.com/v1}",
      "headers": {
        "Authorization": "Bearer ${GOOGLE_ADS_ACCESS_TOKEN}",
        "X-Developer-Token": "${GOOGLE_ADS_DEVELOPER_TOKEN}",
        "X-Customer-ID": "${GOOGLE_ADS_CUSTOMER_ID}"
      }
    },
    "analytics": {
      "type": "http",
      "url": "${GA4_MCP_URL:-https://mcp.google-analytics.example.com/v1}",
      "headers": {
        "Authorization": "Bearer ${GOOGLE_ACCESS_TOKEN}",
        "X-Property-ID": "${GA4_PROPERTY_ID}"
      }
    },
    "stripe": {
      "type": "http",
      "url": "${STRIPE_MCP_URL:-https://mcp.stripe.example.com/v1}",
      "headers": {
        "Authorization": "Bearer ${STRIPE_API_KEY}"
      }
    },
    "database": {
      "type": "http",
      "url": "${DATABASE_MCP_URL:-https://mcp.postgres.example.com/v1}",
      "headers": {
        "Authorization": "Bearer ${DATABASE_ACCESS_TOKEN}",
        "X-Database-URL": "${DATABASE_URL}"
      }
    }
  }
}
